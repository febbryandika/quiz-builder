# PostgreSQL connection string — local Docker Compose in dev (host port 5433), Neon in prod
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/quiz_builder

# Local Docker Postgres credentials — read by docker-compose.yml.
# Keep in sync with DATABASE_URL above.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=quiz_builder

# Better Auth session signing secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me

# Base URL the app is served from
BETTER_AUTH_URL=http://localhost:3000
